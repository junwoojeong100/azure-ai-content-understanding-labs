# Azure AI Content Understanding (Microsoft Foundry) 연결 설정
# infra/setup_azure.sh 를 실행하면 이 값들이 .env 에 자동으로 채워집니다.

# Foundry(=AIServices) 리소스 엔드포인트. 예) https://my-foundry.services.ai.azure.com/
CONTENTUNDERSTANDING_ENDPOINT=

# API 키 (선택). 비워두면 DefaultAzureCredential(az login + 'Cognitive Services User' 역할) 로 인증합니다. (권장)
# 참고: setup_azure.sh 로 만든 리소스는 보안 기본값으로 키 인증이 비활성화되어 있어 Entra ID 인증을 사용합니다.
CONTENTUNDERSTANDING_KEY=

# 작업지시서 커스텀 분석기 ID
WORK_ORDER_ANALYZER_ID=trade_work_order

# Foundry 에 배포한 모델 "배포 이름" (update_defaults 매핑용)
GPT_4_1_DEPLOYMENT=gpt-4.1
GPT_4_1_MINI_DEPLOYMENT=gpt-4.1-mini
TEXT_EMBEDDING_3_LARGE_DEPLOYMENT=text-embedding-3-large

# 커스텀 분석기가 사용할 모델 (배포 이름과 동일하게 유지)
COMPLETION_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-large
